# E2E Test Environment Variables
# Copy this file to .env and fill in the values

# Base URL for the application
BASE_URL=http://localhost:3000

# Test user accounts
TEST_ADMIN_EMAIL=admin@test.com
TEST_ADMIN_PASSWORD=testpassword
TEST_ADMIN_TELEGRAM_ID=166848328

TEST_MANAGER_EMAIL=manager@test.com
TEST_MANAGER_PASSWORD=testpassword
TEST_MANAGER_TELEGRAM_ID=123456789

TEST_ACCOUNTANT_EMAIL=accountant@test.com
TEST_ACCOUNTANT_PASSWORD=testpassword
TEST_ACCOUNTANT_USERNAME=test_accountant

# Telegram OAuth (for authentication tests)
# These are used when testing Telegram login flow
TEST_TELEGRAM_BOT_TOKEN=
TEST_TELEGRAM_CHAT_ID=

# Test chat configurations
TEST_CHAT_ID=-5069248865
TEST_CHAT_SLA_ENABLED=true
TEST_CHAT_SLA_THRESHOLD=60

# Playwright configuration
# Set to 'true' when running in CI
CI=false

# Browser options
# BROWSER=chromium
# HEADLESS=true

# Test timeouts (in milliseconds)
TEST_TIMEOUT=30000
TEST_ACTION_TIMEOUT=10000
TEST_NAVIGATION_TIMEOUT=30000

# Retries
TEST_RETRIES=3

# Output
# test-results/ - Playwright test output
# playwright-report/ - HTML test report
