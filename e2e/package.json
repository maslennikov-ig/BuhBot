{
  "name": "@buhbot/e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for BuhBot",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
