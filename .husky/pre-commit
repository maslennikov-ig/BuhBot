pnpm exec lint-staged

# Detect common secrets in staged changes (exclude .husky and *.md docs)
# Patterns cover: GitHub PAT, Supabase JWT, OpenAI, AWS, Slack, Stripe, Telegram bot
if git diff --cached -- ':!.husky' ':!*.md' | grep -qE '(ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{82}|eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}|sk-proj-[A-Za-z0-9_-]{40,}|sk-[A-Za-z0-9]{48}|sk_live_[A-Za-z0-9]{20,}|pk_live_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{10,}|[0-9]{8,10}:[A-Za-z0-9_-]{35})'; then
  echo "⛔ Possible secret detected in staged changes. Aborting."
  echo "   Patterns checked: GitHub PAT, Supabase JWT, OpenAI, AWS, Slack, Stripe, Telegram"
  echo "   If this is a false positive, commit with --no-verify after careful review."
  exit 1
fi
